<Window x:Class="ShoesShopWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин обуви - Каталог товаров" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ProductItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="8,5"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" Padding="15" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="lblUserInfo" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="Выйти" Margin="40,0,0,0" Click="btnLogout_Click" 
                        Padding="16,7" Background="#E53935" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Фильтры -->
        <Border Grid.Row="1" Background="White" Padding="15" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <WrapPanel>
                <StackPanel Margin="5,0,15,0">
                    <TextBlock Text="Поиск" FontWeight="Medium" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtSearch" Width="260" Height="34" TextChanged="txtSearch_TextChanged"/>
                </StackPanel>
                <StackPanel Margin="5,0,15,0">
                    <TextBlock Text="Категория" FontWeight="Medium" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbCategory" Width="160" Height="34" SelectionChanged="Filter_Changed"/>
                </StackPanel>
                <StackPanel Margin="5,0,15,0">
                    <TextBlock Text="Производитель" FontWeight="Medium" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbManufacture" Width="170" Height="34" SelectionChanged="Filter_Changed"/>
                </StackPanel>
                <StackPanel Margin="5,0,15,0">
                    <TextBlock Text="Поставщик" FontWeight="Medium" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbSupplier" Width="170" Height="34" SelectionChanged="Filter_Changed"/>
                </StackPanel>
                <StackPanel Margin="5,0,15,0">
                    <TextBlock Text="Сортировка" FontWeight="Medium" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbSort" Width="210" Height="34" SelectionChanged="cmbSort_SelectionChanged"/>
                </StackPanel>
                <Button Content="Обновить" Margin="25,24,0,0" Click="btnRefresh_Click" Height="34" Padding="15,0"/>
            </WrapPanel>
        </Border>

        <!-- Карточки (классический стиль как на фото) -->
        <!-- Список товаров -->
        <ListBox x:Name="ProductsList" Grid.Row="2" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="ProductsList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{Binding CardBackground}" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1" 
                CornerRadius="4" 
                Padding="10"
                Margin="5">

                        <Grid Height="140">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <!-- Фото -->
                            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" Padding="10">
                                <Image Source="{Binding ImagePath}" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>

                            <!-- Информация -->
                            <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" Padding="12,8">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,5">
                            <Run Text="{Binding Category}"/>
                            <Run Text=" | "/>
                            <Run Text="{Binding Name}"/>
                                    </TextBlock>

                                    <TextBlock Text="{Binding Description, StringFormat='Описание товара: {0}'}" 
                                   TextWrapping="Wrap" MaxHeight="38" Margin="0,0,0,4"/>

                                    <TextBlock Text="{Binding Manufacturer, StringFormat='Производитель: {0}'}"/>
                                    <TextBlock Text="{Binding Supplier, StringFormat='Поставщик: {0}'}"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Цена: " FontSize="13"/>
                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:F2} ₽'}" 
                                       FontSize="15.5" FontWeight="Bold"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Unit, StringFormat='Единица измерения: {0}'}"/>
                                    <TextBlock Text="{Binding Stock, StringFormat='Количество на складе: {0}'}"/>
                                </StackPanel>
                            </Border>

                            <!-- Скидка -->
                            <Border Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Действующая" HorizontalAlignment="Center" FontSize="11"/>
                                    <TextBlock Text="скидка" HorizontalAlignment="Center" FontSize="11"/>
                                    <TextBlock Text="{Binding Discount, StringFormat='{}{0}%'}" 
                                   FontSize="22" FontWeight="Bold" Foreground="#E53935" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Кнопки администратора -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="15" HorizontalAlignment="Left">
            <Button x:Name="btnAdd" Content="Добавить товар" Click="btnAdd_Click" 
                    Visibility="Collapsed" Margin="0,0,10,0" Padding="12,8"/>
            <Button x:Name="btnEdit" Content="Редактировать" Click="btnEdit_Click" 
                    Visibility="Collapsed" Margin="0,0,10,0" Padding="12,8"/>
            <Button x:Name="btnDelete" Content="Удалить товар" Click="btnDelete_Click" 
                    Visibility="Collapsed" Padding="12,8"/>
        </StackPanel>
    </Grid>
</Window>