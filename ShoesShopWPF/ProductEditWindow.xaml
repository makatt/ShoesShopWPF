<Window x:Class="ShoesShopWPF.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление товара"
        Height="620"
        Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Артикул:" Grid.Row="0"/>
        <TextBox x:Name="txtArticle" Grid.Row="1"/>

        <TextBlock Text="Название:" Grid.Row="2" Margin="0,5,0,0"/>
        <TextBox x:Name="txtName" Grid.Row="3"/>

        <Grid Grid.Row="4" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Категория:"/>
                <ComboBox x:Name="cmbCategory"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                <TextBlock Text="Производитель:"/>
                <ComboBox x:Name="cmbManufacturer"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="5" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Поставщик:"/>
                <ComboBox x:Name="cmbSupplier"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                <TextBlock Text="Единица измерения:"/>
                <ComboBox x:Name="cmbUnit"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="6" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Цена:"/>
                <TextBox x:Name="txtPrice"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="5,0">
                <TextBlock Text="Скидка:"/>
                <TextBox x:Name="txtDiscount" Text="0"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="На складе:"/>
                <TextBox x:Name="txtStock"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="Описание:" Grid.Row="7" Margin="0,5,0,0"/>

        <TextBox x:Name="txtDescription"
                 Grid.Row="8"
                 Height="30"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>

        <!-- Фото -->
        <GroupBox Header="Фото товара" Grid.Row="9" Margin="0,10">
            <StackPanel>

                <Image x:Name="imgPhoto"
                       Height="160"
                       Stretch="Uniform"/>

                <Button Content="Загрузить фото"
                        Width="150"
                        Margin="0,5"
                        HorizontalAlignment="Center"
                        Click="btnLoadPhoto_Click"/>
            </StackPanel>
        </GroupBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="10"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <Button Content="Сохранить"
                    Width="120"
                    Click="btnSave_Click"/>

            <Button Content="Отмена"
                    Width="120"
                    Margin="5,0,0,0"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>