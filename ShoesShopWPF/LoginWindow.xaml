<Window x:Class="ShoesShopWPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - Магазин обуви" Height="502" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Вход в систему" FontSize="28" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,20,0,40"/>

        <StackPanel Grid.Row="1" Margin="0,10">
            <TextBlock Text="Логин:" FontSize="15"/>
            <TextBox x:Name="txtLogin" Height="35" FontSize="15" Margin="0,5"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,10">
            <TextBlock Text="Пароль:" FontSize="15"/>
            <PasswordBox x:Name="txtPassword" Height="35" FontSize="15" Margin="0,5"/>
        </StackPanel>

        <Button Grid.Row="3" Content="Войти" Height="45" FontSize="16" 
                Click="btnLogin_Click"/>
        <Button Grid.Row="4" Content="Войти как Гость" Height="40" FontSize="15" 
                Click="btnGuest_Click"/>
    </Grid>
</Window>