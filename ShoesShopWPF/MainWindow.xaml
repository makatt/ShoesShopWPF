<Window x:Class="ShoesShopWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Каталог товаров"
        Height="780"
        Width="1280"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верх -->
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="lblUserInfo" VerticalAlignment="Center"/>
            <Button Content="Выйти"
                    Margin="10,0,0,0"
                    Click="btnLogout_Click"/>
        </StackPanel>

        <!-- Фильтры -->
        <WrapPanel Grid.Row="1" Margin="0,10">
            <TextBox x:Name="txtSearch"
                     Width="200"
                     TextChanged="txtSearch_TextChanged"/>

            <ComboBox x:Name="cmbCategory"
                      Width="150"
                      Margin="5,0"
                      SelectionChanged="Filter_Changed"/>

            <ComboBox x:Name="cmbManufacture"
                      Width="150"
                      Margin="5,0"
                      SelectionChanged="Filter_Changed"/>

            <ComboBox x:Name="cmbSupplier"
                      Width="150"
                      Margin="5,0"
                      SelectionChanged="Filter_Changed"/>

            <ComboBox x:Name="cmbSort"
                      Width="180"
                      Margin="5,0"
                      SelectionChanged="cmbSort_SelectionChanged"/>

            <Button Content="Обновить"
                    Click="btnRefresh_Click"/>
        </WrapPanel>

        <!-- Товары -->
        <ListBox x:Name="ProductsList" Grid.Row="2" HorizontalContentAlignment="Stretch" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="ProductsList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{Binding CardBackground}" 
                        BorderBrush="#CCCCCC" 
                        BorderThickness="1"  
                        Padding="10"
                        Margin="5">

                        <Grid Height="140">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <!-- Фото -->
                            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" Padding="10">
                                <Image Source="{Binding ImagePath}" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>

                            <!-- Информация -->
                            <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" Padding="12,8">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,5">
                                    <Run Text="{Binding Category}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding Name}"/>
                                                    </TextBlock>

                                    <TextBlock Text="{Binding Description, StringFormat='Описание товара: {0}'}" 
                           TextWrapping="Wrap" MaxHeight="38" Margin="0,0,0,4"/>

                                    <TextBlock Text="{Binding Manufacturer, StringFormat='Производитель: {0}'}"/>
                                    <TextBlock Text="{Binding Supplier, StringFormat='Поставщик: {0}'}"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Цена: " FontSize="13"/>
                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:F2} ₽'}" 
                               FontSize="15.5" FontWeight="Bold"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Unit, StringFormat='Единица измерения: {0}'}"/>
                                    <TextBlock Text="{Binding Stock, StringFormat='Количество на складе: {0}'}"/>
                                </StackPanel>
                            </Border>

                            <!-- Скидка -->
                            <Border Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Действующая" HorizontalAlignment="Center" FontSize="11"/>
                                    <TextBlock Text="скидка" HorizontalAlignment="Center" FontSize="11"/>
                                    <TextBlock Text="{Binding Discount, StringFormat='{}{0}%'}" 
                           FontSize="22" FontWeight="Bold" Foreground="#E53935" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,10,0,0">

            <Button x:Name="btnAdd"
                    Content="Добавить"
                    Click="btnAdd_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="btnEdit"
                    Content="Редактировать"
                    Margin="5,0"
                    Click="btnEdit_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="btnDelete"
                    Content="Удалить"
                    Click="btnDelete_Click"
                    Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>